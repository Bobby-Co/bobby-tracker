# Copy to .env.local. Compose-style (`KEY=value`); restart `next dev` to pick up changes.

# ─── Supabase (shared with Bobby/service) ──────────────────────────────────
# Use the SAME Supabase project as the Bobby CI app — that's how users get
# single-sign-on. The `tracker` schema must be added to API → Exposed schemas
# in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only service-role key. NOT required by any current
# tracker route — progress writes during indexing happen on the
# analyser side using its own SUPABASE_SERVICE_ROLE_KEY env var. Keep
# this slot for future admin-only tracker routes (none today).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Shared auth cookie ────────────────────────────────────────────────────
# Set to the parent domain of BOTH apps so the session cookie is shared.
# Examples:
#   tracker.bobby.example.com + bobby.example.com → ".bobby.example.com"
#   tracker.example.com       + ci.example.com    → ".example.com"
# Leave empty in local dev (different ports don't share cookies; just sign in
# to each app separately on localhost).
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=

# ─── bobby-analyser microservice ───────────────────────────────────────────
# URL of the analyser server (the container from Phase 1). Reachable from
# the tracker's server-side runtime; never exposed to browsers.
BOBBY_ANALYSER_URL=https://analyser.example.com
BOBBY_ANALYSER_TOKEN=

# ─── OpenAI (AI issue composer + embeddings) ───────────────────────────────
# Used by /api/issues/ai-compose (gpt-4.1-mini drafts a structured issue
# from a paragraph + screenshots) and /api/issues/ai-similar
# (text-embedding-3-small powers similarity / duplicate detection).
# Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=
